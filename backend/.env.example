# Runtime
NODE_ENV=development
PORT=4000

# PostgreSQL — full connection string matching docker-compose defaults
DATABASE_URL=postgresql://gradion_user:secure_pass@localhost:5432/expense_system

# MinIO (matches docker-compose defaults)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=gradion_minio
MINIO_ROOT_PASSWORD=secure_minio_pass
MINIO_BUCKET_NAME=receipts
MINIO_PUBLIC_URL=http://localhost:9000

# Auth — replace JWT_SECRET before running
JWT_SECRET=replace-with-a-long-random-string-at-least-24-chars
JWT_EXPIRES_IN=1d

# AI extraction — set your Google AI Studio key (https://aistudio.google.com/apikey) to use Gemini 2.5 Flash.
# Leave blank to use the mock extractor.
AI_PROVIDER_API_KEY=

# CORS — comma-separated origins; defaults to localhost:3000 in development
CLIENT_ORIGIN=
