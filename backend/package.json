{
  "name": "@gradion/backend",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "clean": "rm -rf dist",
    "dev": "nest start --watch",
    "seed": "ts-node -r tsconfig-paths/register src/context/seed/index.ts",
    "start": "node dist/main.js",
    "test": "jest --runInBand --config ./test/jest.config.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/infrastructure/persistence/typeorm/persistence-data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/infrastructure/persistence/typeorm/persistence-data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/infrastructure/persistence/typeorm/persistence-data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/infrastructure/persistence/typeorm/persistence-data-source.ts"
  },
  "dependencies": {
    "@gradion/shared": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "minio": "^8.0.6",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "openai": "^6.34.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tesseract.js": "^7.0.0",
    "typeorm": "^0.3.20",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.7.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.3.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
